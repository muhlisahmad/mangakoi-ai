# ──────────────────────────────────────────────────────────────────────
# .env.example - Environment Configuration for Manga Translation Worker
# ──────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in actual values for your environment.
# REQUIRED variables must be set; OPTIONAL variables have sensible defaults.
#
# This file should NOT be committed to version control (add to .gitignore).
# ──────────────────────────────────────────────────────────────────────

# ── Python Runtime (OPTIONAL) ───────────────────────────────────────
# Ensure Python output is sent straight to stdout (unbuffered).
# Recommended for containerized environments like RunPod.
# Default: "1" (unbuffered output)

PYTHONUNBUFFERED=1


# ── S3 / Cloud Storage (REQUIRED) ────────────────────────────────────
# Configure S3-compatible object storage (R2, MinIO, AWS S3, etc.)
# These are validated at worker startup; worker fails fast if missing.

# S3 endpoint URL (e.g., https://abc123.r2.cloudflarestorage.com)
BUCKET_ENDPOINT_URL=https://your-s3-endpoint.com

# S3 access key ID (AWS access key or R2 API token)
BUCKET_ACCESS_KEY_ID=your_access_key_id_here

# S3 secret access key (AWS secret key or R2 API token secret)
BUCKET_SECRET_ACCESS_KEY=your_secret_access_key_here

# S3 bucket name where input images and output translations are stored
BUCKET_NAME=manga-translation-bucket


# ── Model Cache (OPTIONAL) ──────────────────────────────────────────
# Hugging Face model cache directory. If set, models are loaded from
# this local path instead of re-downloading from HuggingFace Hub.
# Recommended for RunPod Network Volume: /runpod-volume/huggingface
# If not set, models download to default HF cache location (~/.cache/huggingface)

HF_HOME=/runpod-volume/huggingface


# ── Translation Model Settings (OPTIONAL) ───────────────────────────
# Configuration for Qwen3-14B translator quantization.
# Set to "false" if GPU VRAM is insufficient for 4-bit quantization.
# Default: "true" (uses 4-bit quantization to reduce VRAM usage)

USE_4BIT_TRANSLATION=true


# ── Webhook Configuration (OPTIONAL) ────────────────────────────────
# Timeout for webhook POST requests when sending job completion/failure
# notifications to your application. In seconds.
# Default: 10

WEBHOOK_TIMEOUT_SECONDS=10


# ── Logging Configuration (OPTIONAL) ────────────────────────────────
# Control logging verbosity, format, and output location.

# Log level: DEBUG (most verbose), INFO, WARNING, ERROR, CRITICAL
# Default: INFO (recommended for production)
# Use DEBUG for troubleshooting/development
LOG_LEVEL=INFO

# Log format: json (structured, recommended for production/log aggregation)
#             text (human-readable, useful for local development)
# Default: json
LOG_FORMAT=json

# Log output directory where persistent log files are written.
# Log filenames use ISO 8601 date format: worker-YYYY-MM-DD.log
# Recommended for RunPod: /runpod-volume/logs (persists across jobs)
# Default: /runpod-volume/logs
LOG_DIR=/runpod-volume/logs
